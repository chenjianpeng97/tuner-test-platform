{
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "name": "app-web",
  "projectType": "application",
  "root": "shadcn-admin",
  "sourceRoot": "shadcn-admin/src",
  "tags": [
    "scope:frontend",
    "type:app"
  ],
  "metadata": {
    "description": "Existing React + Vite frontend template wrapped by Nx.",
    "owner": "frontend"
  },
  "targets": {
    "init": {
      "metadata": {
        "description": "Initialize frontend dependencies."
      },
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm install",
        "cwd": "shadcn-admin"
      }
    },
    "serve": {
      "metadata": {
        "description": "启动前端 Vite 开发服务器。"
      },
      "executor": "nx:run-commands",
      "options": {
        "cwd": "shadcn-admin",
        "command": "pnpm dev"
      }
    },
    "dev:mock": {
      "metadata": {
        "description": "启动前端开发服务器，使用 MSW Mock Service Worker 拦截 API 请求（不依赖后端）。"
      },
      "executor": "nx:run-commands",
      "options": {
        "cwd": "shadcn-admin",
        "command": "VITE_MSW_ENABLED=true pnpm dev"
      }
    },
    "dev:integration": {
      "metadata": {
        "description": "启动前端开发服务器，关闭 MSW，将 /api/* 代理到本地后端 http://localhost:8000。"
      },
      "executor": "nx:run-commands",
      "options": {
        "cwd": "shadcn-admin",
        "command": "VITE_MSW_ENABLED=false pnpm dev"
      }
    },
    "build": {
      "metadata": {
        "description": "构建前端生产产物。"
      },
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "cwd": "shadcn-admin",
        "command": "pnpm build"
      }
    },
    "lint": {
      "metadata": {
        "description": "运行前端 ESLint 检查。"
      },
      "executor": "nx:run-commands",
      "options": {
        "cwd": "shadcn-admin",
        "command": "pnpm lint"
      }
    },
    "preview": {
      "metadata": {
        "description": "以 Vite 预览模式启动已构建的前端产物。"
      },
      "executor": "nx:run-commands",
      "options": {
        "cwd": "shadcn-admin",
        "command": "pnpm preview"
      }
    },
    "format-check": {
      "metadata": {
        "description": "检查前端代码格式是否符合 Prettier 规范。"
      },
      "executor": "nx:run-commands",
      "options": {
        "cwd": "shadcn-admin",
        "command": "pnpm format:check"
      }
    },
    "format": {
      "metadata": {
        "description": "使用 Prettier 格式化前端代码。"
      },
      "executor": "nx:run-commands",
      "options": {
        "cwd": "shadcn-admin",
        "command": "pnpm format"
      }
    },
    "knip": {
      "metadata": {
        "description": "分析前端未使用的文件、导出与依赖。"
      },
      "executor": "nx:run-commands",
      "options": {
        "cwd": "shadcn-admin",
        "command": "pnpm knip"
      }
    },
    "generate-api": {
      "metadata": {
        "description": "根据 openspec/contracts/app-api.openapi.json 生成前端 API client（react-query + axios）及 MSW handler。"
      },
      "executor": "nx:run-commands",
      "options": {
        "cwd": "shadcn-admin",
        "command": "pnpm exec orval --config orval.config.ts"
      }
    },
    "test-cypress": {
      "metadata": {
        "description": "运行 Cypress E2E 渲染断言测试（替代已删除的 BDD UI-only feature 文件）。需要前端开发服务器在 BASE_URL（默认 http://localhost:5173）上运行。"
      },
      "executor": "nx:run-commands",
      "options": {
        "cwd": "shadcn-admin",
        "command": "pnpm exec cypress run --e2e --headless"
      }
    }
  }
}